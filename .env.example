# GitHub Token (REQUIRED - the app works read-only with just this)
# Create at: https://github.com/settings/tokens
# Read-only analysis needs public repo access; creating issues requires repo scope.
GITHUB_TOKEN=your_github_personal_access_token_here

# OpenAI API Key (optional - enables AI-generated resurrection plans and issue bodies)
OPENAI_API_KEY=your_openai_api_key_here

# Stack Auth Configuration (optional - enables user login)
NEXT_PUBLIC_STACK_PROJECT_ID=your_stack_project_id_here
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your_publishable_key_here
STACK_SECRET_SERVER_KEY=your_secret_key_here

# API Configuration
# leave empty to use same-origin
NEXT_PUBLIC_API_URL=
